<?xml version="1.0" encoding="UTF-8"?>
<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy name="ttkDebrisTracer" class="ttkDebrisTracer" label="TTK DebrisTracer">
      <Documentation short_help="Post-process tracked trajectories and surfaces"
                     long_help="Compute per-trajectory stats, extract surfaces, and fuse compatible trajectory segments into longer chains."/>
    
      <!-- INPUTS -->
      <InputProperty name="InputGrid" command="SetInputConnection" port_index="0">
        <ProxyGroupDomain name="groups"><Group name="sources"/><Group name="filters"/></ProxyGroupDomain>
        <DataTypeDomain name="input_type"><DataType value="vtkUnstructuredGrid"/></DataTypeDomain>
        <Documentation>Output grid produced by TrackingFromField (trajectory segments as cells).</Documentation>
      </InputProperty>
    
      <InputProperty name="InputSet" command="SetInputConnection" port_index="1">
        <ProxyGroupDomain name="groups"><Group name="sources"/><Group name="filters"/></ProxyGroupDomain>
        <DataTypeDomain name="input_type"><DataType value="vtkDataSet"/></DataTypeDomain>
        <Documentation>Original dataset providing point scalars (one per frame) used by surface extraction.</Documentation>
      </InputProperty>
    
      <!-- PARAMETERS -->
 

      <!-- Fusion / chaining -->
      <DoubleVectorProperty name="cosCol" command="SetcosCol" label="Chaining: Min cosine similarity"
                            number_of_elements="1" default_values="0.96">
        <Documentation>Minimum cosine similarity between average directions to allow linking two trajectories.</Documentation>
      </DoubleVectorProperty>
    
      <DoubleVectorProperty name="maxRadius" command="SetmaxRadius" label="Chaining: Max 3D distance²"
                            number_of_elements="1" default_values="40.0">
        <Documentation>Maximum squared distance (x,y,t) at the linking frame between the predicted end and the start point.</Documentation>
      </DoubleVectorProperty>
    
      <IntVectorProperty name="maxFrameDist" command="SetmaxFrameDist" label="Chaining: frame gap"
                         number_of_elements="1" default_values="20">
        <Documentation>Upper and Lower bound on the frame difference between end(i) and start(j) for a valid link.</Documentation>
      </IntVectorProperty>

  


      <!-- Surface extraction -->

      <IntVectorProperty name="onlyFrameSurface" command="SetonlyFrameSurface" label="Compute only frame Surface ?"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <BooleanDomain name="bool"/>
      </IntVectorProperty>
	  <IntVectorProperty name="frameSurface" command="SetframeSurface" label="Surface: Frame index"
                         number_of_elements="1" default_values="0">
        <Documentation>Frame index on which to display the surface vertices.</Documentation>
      </IntVectorProperty>
	  
	  <IntVectorProperty name="maxSurfSize" command="SetmaxSurfSize" label="Max Surface Size in vertex"
                         number_of_elements="1" default_values="10000">
      </IntVectorProperty>
      <DoubleVectorProperty name="errSurf" command="SeterrSurf"
                            label="Minimum bins Otsu Threshold"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Surface parameter: threshold for BFS or β for Random Walker (controls region growth strength).</Documentation>
      </DoubleVectorProperty>
      <DoubleVectorProperty name="persisThresh" command="SetpersisThresh"
                            label="Persistence Threshold (MergeTree)"
                            number_of_elements="1" default_values="0.0">
        <Documentation></Documentation>
      </DoubleVectorProperty>

      <IntVectorProperty name="surfaceMethod" command="SetsurfaceMethod" label="Surface: Method"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <EnumerationDomain name="enum">
          <Entry value="0" text="BFS (region grow)"/>
          <Entry value="1" text="Random Walker (multilabel)"/>
		  <Entry value="2" text="Persistence-based"/>
		  <Entry value="3" text="MergeTree"/>
        </EnumerationDomain>
        <Documentation>Choose how surfaces are extracted on the selected frame.</Documentation>
      </IntVectorProperty>
    



      <!-- Units -->
      <DoubleVectorProperty name="spatialScale" command="SetspatialScale" label="Units: Spatial scale (px→mm)"
                            number_of_elements="1" default_values="1.0">
        <Documentation>Spatial conversion factor (millimeters per pixel). Used for velocity thresholds.</Documentation>
      </DoubleVectorProperty>
    
      <DoubleVectorProperty name="interFrame" command="SetinterFrame" label="Units: Inter-frame time (μs)"
                            number_of_elements="1" default_values="1.0">
        <Documentation>Time between two consecutive frames, in microseconds. Used for velocity computation.</Documentation>
      </DoubleVectorProperty>
    
      <IntVectorProperty name="convertDur" command="SetconvertDur" label="Units: Durations in seconds"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>When enabled, durations are reported in seconds (otherwise in frames).</Documentation>
      </IntVectorProperty>




      <!-- Directional filtering -->
      <IntVectorProperty name="enableFilteringMinVx"
                         command="SetenableFilteringMinVx"
                         label="Vx filtering ?"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable to show and activate directional filtering parameters.</Documentation>
      </IntVectorProperty>

	  <IntVectorProperty name="enableFilteringCosY"
                         command="SetenableFilteringCosY"
                         label="Cos Y filtering ?"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable to show and activate directional filtering parameters.</Documentation>
	</IntVectorProperty>    

	<IntVectorProperty name="enableFilteringTimeOrigin"
                         command="SetenableFilteringTimeOrigin"
                         label="Time for x0 filtering ?"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable to show and activate directional filtering parameters.</Documentation>
	</IntVectorProperty>    


	<IntVectorProperty name="enableFilteringDuration"
                         command="SetenableFilteringDuration"
                         label="Duration Filtering ?"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable to show and activate directional filtering parameters.</Documentation>
	</IntVectorProperty>   

      <DoubleVectorProperty name="minVx" command="SetminVx" label="Filter: Min |Vx| (mm/s)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Minimum absolute X velocity required to accept a trajectory (after unit conversion).</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringMinVx"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty name="maxVx" command="SetmaxVx" label="Filter: Max |Vx| (mm/s)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Minimum absolute X velocity required to accept a trajectory (after unit conversion).</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringMinVx"
                                   value="1"/>
        </Hints>
	</DoubleVectorProperty>


      <DoubleVectorProperty name="filtreY" command="SetfiltreY"
                            label="Direction: Y cosine max"
                            number_of_elements="1" default_values="1.0">
        <Documentation> Interval ([-value; value]) on the normalized Y direction (cosine) for trajectory acceptance.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringCosY"
                                   value="1"/>
        </Hints>
	  </DoubleVectorProperty>
     
      <IntVectorProperty name="xOrigin" command="SetxOrigin" label="X Origin"
                            number_of_elements="1" default_values="0">
        <Documentation>X coordinate of the reference vertical line used by the time-origin filter.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

   <IntVectorProperty name="duraMin" command="SetduraMin" label="Duration min"
                            number_of_elements="1" default_values="0">
        <Documentation>Minimum trajectory duration (in frames) to keep.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringDuration"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="minTimeOrigin" command="SetminTimeOrigin" label="Min Time Origin"
                            number_of_elements="1" default_values="0">
        <Documentation>Minimum absolute X velocity required to accept a trajectory (after unit conversion).</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="minYTimeOrigin" command="SetminYTimeOrigin" label="Min Y Time Origin"
                            number_of_elements="1" default_values="0">
        <Documentation>Minimum absolute X velocity required to accept a trajectory (after unit conversion).</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="maxYTimeOrigin" command="SetmaxYTimeOrigin" label="Max Y Time Origin"
                            number_of_elements="1" default_values="20000">
        <Documentation>Minimum absolute X velocity required to accept a trajectory (after unit conversion).</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>
   


<!--      <DoubleVectorProperty name="threshCratereAngle" command="SetthreshCratereAngle"
                            label="Crater: Min cosine (|cosθ|)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Minimum absolute cosine between trajectory direction and vector towards crater center.</Documentation>
      </DoubleVectorProperty>
-->
      
      <IntVectorProperty name="extendTraj" command="SetextendTraj" label="Extend merged chains to t=0"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>When enabled, merged trajectories are drawn starting from frame 0 instead of their first frame.</Documentation>
      </IntVectorProperty>
    
      <!-- DEBUG WIDGETS -->
      ${DEBUG_WIDGETS}
      
     <PropertyGroup panel_widget="Line" label="Fusion / chaining">
       <Property name="cosCol"/>
       <Property name="maxRadius"/>
       <Property name="maxFrameDist"/>
     </PropertyGroup>  

     <PropertyGroup panel_widget="Line" label="Surface extraction">
	   <Property name="surfaceMethod"/>
	   <Property name="frameSurface"/>
	   <Property name="onlyFrameSurface"/>
	   <Property name="maxSurfSize"/>
	   <Property name="errSurf"/>
	   <Property name="persisThresh"/>
     </PropertyGroup>

     <PropertyGroup panel_widget="Line" label="Units">
       <Property name="spatialScale"/>
       <Property name="interFrame"/>
       <Property name="convertDur"/>

     </PropertyGroup>

     <PropertyGroup panel_widget="Line" label="Filtering">
		<Property name="enableFilteringMinVx"/>
		<Property name="enableFilteringCosY"/>
		<Property name="enableFilteringTimeOrigin"/>
		<Property name="enableFilteringDuration"/>
		<Property name="minVx"/>
		<Property name="maxVx"/>
		<Property name="filtreY"/>
		<Property name="xOrigin"/>
		<Property name="minTimeOrigin"/>
		<Property name="maxYTimeOrigin"/>
		<Property name="minYTimeOrigin"/>
		<Property name="duraMin"/>
     </PropertyGroup>


    
      <OutputPort name="Statistics"   index="0" id="port0"/>
      <OutputPort name="Trajectories" index="1" id="port1"/>
      <OutputPort name="Surfaces"     index="2" id="port2"/>
      <OutputPort name="Chains"       index="3" id="port3"/>
    
      <Hints>
        <ShowInMenu category="TTK - Misc"/>
      </Hints>
    </SourceProxy>
 
 
 </ProxyGroup>
</ServerManagerConfiguration>

