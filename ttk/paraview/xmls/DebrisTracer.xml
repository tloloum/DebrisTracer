<?xml version="1.0" encoding="UTF-8"?>
<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy name="ttkDebrisTracer" class="ttkDebrisTracer" label="TTK DebrisTracer">
      <Documentation short_help="Post-process tracked trajectories and surfaces"
                     long_help="Compute per-trajectory stats, extract surfaces, and fuse compatible trajectory segments into longer chains."/>
    
      <!-- INPUTS -->
      <InputProperty name="InputGrid" command="SetInputConnection" port_index="0">
        <ProxyGroupDomain name="groups"><Group name="sources"/><Group name="filters"/></ProxyGroupDomain>
        <DataTypeDomain name="input_type"><DataType value="vtkUnstructuredGrid"/></DataTypeDomain>
        <Documentation>Output grid produced by TrackingFromField (trajectory segments as cells).</Documentation>
      </InputProperty>
    
      <InputProperty name="InputSet" command="SetInputConnection" port_index="1">
        <ProxyGroupDomain name="groups"><Group name="sources"/><Group name="filters"/></ProxyGroupDomain>
        <DataTypeDomain name="input_type"><DataType value="vtkDataSet"/></DataTypeDomain>
        <Documentation>Original dataset providing point scalars (one per frame) used by surface extraction.</Documentation>
      </InputProperty>
    
      <!-- PARAMETERS -->
 

      <!-- Fusion / chaining -->
      <DoubleVectorProperty name="cosCol" command="SetcosCol" label="θmax (°)"
                            number_of_elements="1" default_values="20">
        <Documentation>Maximum angular deviation (in degrees) between two trajectory segments allowed for chaining.</Documentation>
      </DoubleVectorProperty>
    
      <DoubleVectorProperty name="maxRadius" command="SetmaxRadius" label="dmax (pixel)"
                            number_of_elements="1" default_values="15">
        <Documentation>Maximum spatial distance (in pixels) between the extrapolated end of segment i and the start of segment j at the linking frame.</Documentation>
      </DoubleVectorProperty>
    
      <IntVectorProperty name="maxFrameDist" command="SetmaxFrameDist" label="δmax (Frame)"
                         number_of_elements="1" default_values="30">
        <Documentation>Maximum temporal gap (in frames) between the end of segment i and the start of segment j for a valid chain link.</Documentation>
      </IntVectorProperty>


      <!-- Surface extraction -->

      <IntVectorProperty name="onlyFrameSurface" command="SetonlyFrameSurface" label="Compute only frame Surface ?"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <BooleanDomain name="bool"/>
		<Documentation> If enabled, surface computation is restricted to the selected frame index only. </Documentation>
      </IntVectorProperty>

	  <IntVectorProperty name="frameSurface" command="SetframeSurface" label="Surface: Frame index"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <Documentation>Index of the frame on which debris surfaces are extracted and displayed.</Documentation>
      </IntVectorProperty>
	  
	  <IntVectorProperty name="maxSurfSize" command="SetmaxSurfSize" label="Max Surface Size in vertex"
		  				 number_of_elements="1" default_values="10000">
						 <Documentation>Segmentations larger than this vertex count are discarded as likely noise or background artifacts.</Documentation>
	  </IntVectorProperty>

      <DoubleVectorProperty name="errSurf" command="SeterrSurf"
                            label="Minimum bins Otsu Threshold"
                            number_of_elements="1" default_values="0.0" panel_visibility="advanced">
        <Documentation>Number of histogram bins used for local Otsu thresholding during surface cleaning; set to 0 to disable.</Documentation>
	 </DoubleVectorProperty>

      <DoubleVectorProperty name="persisThresh" command="SetpersisThresh"
                            label="Persistence Threshold (MergeTree)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Persistence threshold for the MergeTree surface method; arcs below this value are pruned.</Documentation>
      </DoubleVectorProperty>

    



      <!-- Units -->
      <DoubleVectorProperty name="spatialScale" command="SetspatialScale" label="Spatial scale (px/mm)"
                            number_of_elements="1" default_values="1.0">
        <Documentation>Physical size of one millimeter in pixels; used to convert pixel displacements to physical velocities.</Documentation>
      </DoubleVectorProperty>
    
      <DoubleVectorProperty name="interFrame" command="SetinterFrame" label="Units: Inter-frame time (μs)"
                            number_of_elements="1" default_values="1.0">
        <Documentation>Time elapsed between two consecutive frames in microseconds; used together with spatial scale for velocity computation.</Documentation>
      </DoubleVectorProperty>
    
      <IntVectorProperty name="convertDur" command="SetconvertDur" label="Units: Durations in seconds"
                         number_of_elements="1" default_values="0" panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>If enabled, trajectory durations in the output table are expressed in seconds instead of frames.</Documentation>
      </IntVectorProperty>




      <!-- Directional filtering -->
      <IntVectorProperty name="enableFilteringMinVx"
                         command="SetenableFilteringMinVx"
                         label="Enable axial velocity filter"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable filtering by horizontal velocity; exposes the Min/Max Vx parameters.</Documentation>
      </IntVectorProperty>

	  <IntVectorProperty name="enableFilteringCosY"
                         command="SetenableFilteringCosY"
                         label="Enable ejection angle filter"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable filtering by ejection angle; exposes the Max ejection angle parameter.</Documentation>
	</IntVectorProperty>    

	<IntVectorProperty name="enableFilteringTimeOrigin"
                         command="SetenableFilteringTimeOrigin"
                         label="Enable impact origin filter"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable filtering by spatial origin; keeps only trajectories whose back-extrapolation passes through the defined impact zone.</Documentation>
	</IntVectorProperty>    


	<IntVectorProperty name="enableFilteringDuration"
                         command="SetenableFilteringDuration"
                         label="Enable minimum duration filter"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>Enable filtering by minimum trajectory duration; exposes the Min duration parameter.</Documentation>
	</IntVectorProperty>   

      <DoubleVectorProperty name="minVx" command="SetminVx" label="Min Vx (mm/s)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Minimum accepted horizontal velocity magnitude (m/s) after unit conversion; trajectories below this value are rejected.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringMinVx"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty name="maxVx" command="SetmaxVx" label="Max Vx (mm/s)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Maximum accepted horizontal velocity magnitude (m/s) after unit conversion; trajectories above this value are rejected.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringMinVx"
                                   value="1"/>
        </Hints>
	</DoubleVectorProperty>


      <DoubleVectorProperty name="filtreY" command="SetfiltreY"
                            label="Θmax (°)"
                            number_of_elements="1" default_values="80">
							<Documentation> Maximum accepted ejection angle (in degrees) relative to the horizontal axis; trajectories more vertical than this are rejected. 
							</Documentation>
							<Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringCosY"
                                   value="1"/>
        </Hints>
	  </DoubleVectorProperty>
     
      <IntVectorProperty name="xOrigin" command="SetxOrigin" label="X Origin"
                            number_of_elements="1" default_values="0">
        <Documentation>X coordinate (in pixels) representing the impact point, used by the origin filter.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

   <IntVectorProperty name="duraMin" command="SetduraMin" label="Min duration (frames)"
                            number_of_elements="1" default_values="0">
        <Documentation>Minimum trajectory duration (in frames) required to keep a trajectory.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringDuration"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="minTimeOrigin" command="SetminTimeOrigin" label="Earliest origin frame"
                            number_of_elements="1" default_values="0">
        <Documentation>Earliest frame at which a trajectory's back-extrapolated origin is considered valid.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="minYTimeOrigin" command="SetminYTimeOrigin" label="Impact zone Y min (px)"
                            number_of_elements="1" default_values="0">
        <Documentation>Lower Y bound (in pixels) of the accepted impact zone used by the origin filter.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>

    <IntVectorProperty name="maxYTimeOrigin" command="SetmaxYTimeOrigin" label="Impact zone Y max (px)"
                            number_of_elements="1" default_values="20000">
        <Documentation>Upper Y bound (in pixels) of the accepted impact zone used by the origin filter.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="enableFilteringTimeOrigin"
                                   value="1"/>
        </Hints>
	</IntVectorProperty>
   


<!--      <DoubleVectorProperty name="threshCratereAngle" command="SetthreshCratereAngle"
                            label="Crater: Min cosine (|cosθ|)"
                            number_of_elements="1" default_values="0.0">
        <Documentation>Minimum absolute cosine between trajectory direction and vector towards crater center.</Documentation>
      </DoubleVectorProperty>
-->
      
      <IntVectorProperty name="extendTraj" command="SetextendTraj" label="Extend lines to t=0"
                         number_of_elements="1" default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>When enabled, trajectories lines are drawn starting from frame 0 instead of their first frame of detection.</Documentation>
      </IntVectorProperty>
    
      <!-- DEBUG WIDGETS -->
      ${DEBUG_WIDGETS}
      
     <PropertyGroup panel_widget="Line" label="Concatenation criteria">
       <Property name="cosCol"/>
       <Property name="maxRadius"/>
       <Property name="maxFrameDist"/>
     </PropertyGroup>  

     <PropertyGroup panel_widget="Line" label="Debris mass estimation">
	   <Property name="persisThresh"/>
	   <Property name="errSurf"/>
	   <Property name="maxSurfSize"/>
	   <Property name="onlyFrameSurface"/>
	   <Property name="frameSurface"/>
     </PropertyGroup>

     <PropertyGroup panel_widget="Line" label="Units">
       <Property name="spatialScale"/>
       <Property name="interFrame"/>
       <Property name="convertDur"/>

     </PropertyGroup>

     <PropertyGroup panel_widget="Line" label="Filtering non physical trajectory">
		<Property name="enableFilteringMinVx"/>
		<Property name="enableFilteringCosY"/>
		<Property name="enableFilteringTimeOrigin"/>
		<Property name="enableFilteringDuration"/>
		<Property name="minVx"/>
		<Property name="maxVx"/>
		<Property name="filtreY"/>
		<Property name="xOrigin"/>
		<Property name="minTimeOrigin"/>
		<Property name="maxYTimeOrigin"/>
		<Property name="minYTimeOrigin"/>
		<Property name="duraMin"/>
     </PropertyGroup>


    
      <OutputPort name="Statistics"   index="0" id="port0"/>
      <OutputPort name="Trajectories" index="1" id="port1"/>
      <OutputPort name="Surfaces"     index="2" id="port2"/>
      <OutputPort name="Chains"       index="3" id="port3"/>
    
      <Hints>
        <ShowInMenu category="TTK - Misc"/>
      </Hints>
    </SourceProxy>
 
 
 </ProxyGroup>
</ServerManagerConfiguration>

